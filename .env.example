TELEGRAM_BOT_TOKEN=your_bot_token_here
ALLOWED_TELEGRAM_USER_ID=123456789

# Optional: change local storage root.
DATA_DIR=data

# Worker polling.
WORKER_POLL_INTERVAL_SECONDS=3
QUEUE_SCAN_LIMIT=100

# Choose ONE integration style for your existing Reddit summarizer pipeline.
# 1) Shell command wrapper. Available placeholders:
#    {reddit_url} / {url} / {job_id} / {output_dir} / {result_dir}
# Example:
# REDDIT_PIPELINE_COMMAND=python /absolute/path/to/pipeline.py --url "{reddit_url}" --output-dir {output_dir}
REDDIT_PIPELINE_COMMAND=

# 2) Importable callable in module:function form.
# Example:
# REDDIT_PIPELINE_CALLABLE=my_pipeline.runner:run_pipeline
REDDIT_PIPELINE_CALLABLE=

# File produced by your pipeline inside the result directory.
PIPELINE_OUTPUT_FILENAME=final_summary.json
